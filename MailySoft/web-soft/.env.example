# URL base de la API. En dev usamos ruta relativa: el proxy de Vite
# (vite.config.ts) reenvía /api → http://localhost:8000, así front y backend
# son el MISMO origen y las cookies httpOnly funcionan sin líos de CORS.
VITE_API_URL=/api/v1

# Sentry (observabilidad de errores del frontend). Déjalo VACÍO en local → dormido.
# En producción ponlo al CONSTRUIR (npm run build) para que se active.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

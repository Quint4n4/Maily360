# ============================================================
# Maily Soft — Variables de entorno
# Copia este archivo como .env.dev (para Docker local) o .env
# NUNCA commitear archivos con valores reales
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=cambia-esto-por-un-secreto-real-de-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
DB_LOG_LEVEL=WARNING

# --- Base de datos ---
DATABASE_URL=postgres://mailysoft:mailysoft@localhost:5432/mailysoft_dev
DB_CONN_MAX_AGE=60
# Modo de fijado del GUC de tenant para RLS: "session" (default, actual) o
# "local" (SET LOCAL, requerido para pgbouncer en modo transacción). Ver
# docs/design/pgbouncer-rls-escalabilidad.md antes de cambiar a "local" en prod.
DB_TENANT_GUC_MODE=session

# --- Redis ---
REDIS_URL=redis://localhost:6379/1

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Segundos de retención de resultados de tareas en el backend (default: 3600 = 1h)
CELERY_RESULT_EXPIRES=3600

# --- JWT ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
# FIX-B10: clave independiente para firmar JWTs.
# PRODUCCIÓN: OBLIGATORIO. Sin este valor el backend no arranca en settings/production.py.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(50))"
# DESARROLLO: opcional; si se omite, se usa DJANGO_SECRET_KEY como fallback.
JWT_SIGNING_KEY=

# --- DRF ---
DRF_PAGE_SIZE=25
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute

# --- Email ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mailysoft.mx

# --- CORS ---
# Incluir los puertos del frontend Vite (5173) y otros entornos de dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# --- Auth cookies (patrón híbrido: access en memoria, refresh en cookie httpOnly) ---
# AUTH_COOKIE_SECURE: True en producción (HTTPS obligatorio). False en desarrollo local.
# En production.py se fuerza a True; aquí se documenta el default.
AUTH_COOKIE_SECURE=False

# --- CSRF ---
# Orígenes de confianza para la validación CSRF de Django.
# Debe incluir el origen exacto (esquema + host + puerto) del frontend.
# En producción agregar el dominio real: https://app.mailysoft.mx
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# --- AWS S3 (almacenamiento de archivos) ---
DJANGO_DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
# BAJO-3: si AWS_S3_CUSTOM_DOMAIN está configurado en producción, DEBE activarse
# también AWS_CLOUDFRONT_SIGNED=True para que las imágenes clínicas se sirvan
# con URLs firmadas de CloudFront (no accesibles públicamente sin firma).
# Sin esta variable, el backend en producción rechaza el arranque con
# ImproperlyConfigured para evitar exponer datos de salud.
AWS_CLOUDFRONT_SIGNED=False

# --- Sentry (observabilidad de errores) ---
# Déjalo VACÍO en local → Sentry queda dormido (no envía nada).
# En producción/Railway pega aquí el DSN de tu proyecto Sentry → se activa solo.
SENTRY_DSN=
# Etiqueta del ambiente que verás en Sentry (production / staging).
SENTRY_ENVIRONMENT=production
# Muestreo de performance tracing (0.0 = apagado; 0.1 = 10% de las transacciones).
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Stripe (pagos) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# --- WhatsApp / Meta API ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Twilio (alternativa a WhatsApp) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Recetas — QR de verificación pública (F5) ---
# Secreto HMAC-SHA256 para firmar/validar tokens de QR de receta.
# En producción OBLIGATORIO: valor independiente de DJANGO_SECRET_KEY con ≥50 chars.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(50))"
# En desarrollo: si se omite, usa DJANGO_SECRET_KEY como fallback.
PRESCRIPTION_VERIFY_SECRET=
# URL del frontend donde vive la pantalla pública de verificación.
# Ejemplo producción: https://app.mailysoft.mx
PRESCRIPTION_VERIFY_BASE_URL=http://localhost:5173
# Throttle para el endpoint público (30 consultas por minuto por IP).
DRF_THROTTLE_VERIFY=30/minute

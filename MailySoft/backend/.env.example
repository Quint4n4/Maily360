# ============================================================
# Maily Soft — Variables de entorno
# Copia este archivo como .env.dev (para Docker local) o .env
# NUNCA commitear archivos con valores reales
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=cambia-esto-por-un-secreto-real-de-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
DB_LOG_LEVEL=WARNING

# --- Base de datos ---
DATABASE_URL=postgres://mailysoft:mailysoft@localhost:5432/mailysoft_dev
DB_CONN_MAX_AGE=60

# --- Redis ---
REDIS_URL=redis://localhost:6379/1

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- JWT ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
# FIX-10: clave independiente para firmar JWTs. En prod, usar un secreto de alta
# entropía (mínimo 50 chars). Si no se define, se usa DJANGO_SECRET_KEY como fallback.
JWT_SIGNING_KEY=

# --- DRF ---
DRF_PAGE_SIZE=25
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute

# --- Email ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mailysoft.mx

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- AWS S3 (almacenamiento de archivos) ---
DJANGO_DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# --- Sentry (monitoreo de errores) ---
SENTRY_DSN=

# --- Stripe (pagos) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# --- WhatsApp / Meta API ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Twilio (alternativa a WhatsApp) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

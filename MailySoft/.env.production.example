# =============================================================================
# Maily Soft — Variables de entorno para PRODUCCIÓN (Railway)
#
# Esto es SOLO la PLANTILLA (no lleva valores reales; NO se sube con secretos).
# En Railway estas variables se cargan en "Variables" de cada servicio.
# Las que dicen ${{...}} son "reference variables" de Railway (se autollenan al
# vincular el plugin de Postgres / Redis).
# =============================================================================

# --- Módulo de settings (ya viene por default en el Dockerfile) ---
DJANGO_SETTINGS_MODULE=config.settings.production

# --- Secretos (genera cada uno DISTINTO y largo; NO reutilices entre sí) ---
# Genera cada valor con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=__genera_una_cadena_larga_aleatoria__
JWT_SIGNING_KEY=__genera_OTRA_distinta__
PRESCRIPTION_VERIFY_SECRET=__genera_OTRA_para_el_QR_de_recetas__

# --- Dominios ---
# Railway te da un dominio tipo  tu-app.up.railway.app.
# Wildcards para que funcione desde el primer deploy sin conocer el dominio exacto.
# (Puedes apretarlo luego al dominio real por seguridad.)
DJANGO_ALLOWED_HOSTS=.railway.app
CSRF_TRUSTED_ORIGINS=https://*.railway.app
# Frontend y API van en el MISMO dominio → CORS no se usa. Déjalo vacío.
CORS_ALLOWED_ORIGINS=

# URL pública de la app, para el QR de verificación de recetas (si falta, el QR
# apunta a http://localhost:5173 y no abre). Debe ser tu dominio REAL de Railway.
# Ponla también en el servicio worker (él genera el PDF con el QR).
PRESCRIPTION_VERIFY_BASE_URL=https://TU-APP.up.railway.app

# --- Base de datos (Railway Postgres) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Redis / Celery (Railway Redis) ---
REDIS_URL=${{Redis.REDIS_URL}}
CELERY_BROKER_URL=${{Redis.REDIS_URL}}
CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}

# --- Media en Cloudinary ---
# CLOUDINARY_URL se copia del dashboard de Cloudinary → "Account Details".
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
DJANGO_DEFAULT_FILE_STORAGE=cloudinary_storage.storage.MediaCloudinaryStorage

# --- Email (OPCIONAL; sin esto la app corre pero no envía correos) ---
# EMAIL_HOST=smtp.tu-proveedor.com
# EMAIL_HOST_USER=usuario
# EMAIL_HOST_PASSWORD=contraseña
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Maily <no-reply@tudominio.com>

# --- Sentry (OPCIONAL; monitoreo de errores en producción) ---
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
# SENTRY_ENVIRONMENT=demo-clinica

# =============================================================================
# ⚠️  SOLO en el servicio WORKER (Celery) agrega ADEMÁS de todo lo anterior:
#       RUN_MIGRATIONS=false
#     (las migraciones las corre únicamente el servicio web)
# =============================================================================
